{
    "title": "独自キーボード設定",
    "rules": [
        {
            "description": "英数+かな→viの編集モードを抜けてIMEもオフ",
            "manipulators": [
                {
                    "from": {
                        "key_code": "lang1",
                        "modifiers": {
                            "mandatory": [
                                "left_shift"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "lang2"
                        },
                        {
                            "key_code": "escape"
                        }
                    ],
                    "type": "basic"
                }
            ]
        },
        {
            "description": "英数/かなをShiftに変換(同時押しの場合)",
            "manipulators": [
                {
                    "from": {
                        "key_code": "lang2"
                    },
                    "to": [
                        {
                            "key_code": "left_shift",
                            "lazy": true
                        }
                    ],
                    "to_if_alone": [
                        {
                            "key_code": "lang2"
                        }
                    ],
                    "type": "basic"
                },
                {
                    "from": {
                        "key_code": "lang1"
                    },
                    "to": [
                        {
                            "key_code": "left_shift",
                            "lazy": true
                        }
                    ],
                    "to_if_alone": [
                        {
                            "key_code": "lang1"
                        }
                    ],
                    "type": "basic"
                }
            ]
        },
